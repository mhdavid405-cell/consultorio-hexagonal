# ============================================================
# .env.example — Consultorio Médico
# Copia este archivo como .env y ajusta los valores.
# NUNCA subas tu .env real a Git.
# ============================================================

# Base de datos MySQL
# Si usas Docker con MySQL local en tu máquina:
MYSQL_HOST=host.docker.internal
# Si usas un contenedor MySQL dentro de docker-compose:
# MYSQL_HOST=db

MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=tu_password_aqui
MYSQL_DATABASE=consultorio
