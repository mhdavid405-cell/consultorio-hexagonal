<?php
// public/index.php - Front controller
require_once __DIR__ . '/../config/database.php';
require_once __DIR__ . '/../config/paths.php';

// Obtener la ruta
$request = $_SERVER['REQUEST_URI'];
$request = str_replace('/consultorio_hexagonal/public', '', $request);
$request = trim($request, '/');

// Si es la raíz, mostrar tu index.php original
if ($request === '') {
    require_once __DIR__ . '/../templates/index.php';
    exit;
}

// Mapeo de rutas
$routes = [
    'login' => '../templates/auth/login.php',
    'menu' => '../templates/menu.php',
    'menu_paciente' => '../templates/menu_paciente.php',
    'cambiar_clave' => '../templates/auth/cambiar_clave.php',
    'nueva_clave' => '../templates/auth/nueva_clave.php',
    'registro_paciente' => '../templates/auth/registro_paciente.php',
    'paciente_citas' => '../templates/paciente/paciente_citas.php',
    'paciente_datos' => '../templates/paciente/paciente_datos.php',
    'paciente_cita_nueva' => '../templates/paciente/paciente_cita_nueva.php',
    'pacientes' => '../templates/pacientes/lista.php',
    'citas' => '../templates/citas/lista.php',
];

if (isset($routes[$request])) {
    require_once $routes[$request];
    exit;
}

echo "<h1>404 - Página no encontrada</h1>";
echo "<p>Ruta: $request</p>";
echo "<p><a href='" . BASE_URL . "'>Volver al inicio</a></p>";
